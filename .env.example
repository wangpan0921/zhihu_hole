# ===== LLM (二选一即可，优先级 anthropic > openai) =====
# 文案生成：填一个就行。
# 公司内部网关 / 自建代理：把 BASE_URL 填成网关地址即可（留空走官方）。

# Anthropic / Claude
ANTHROPIC_API_KEY=
# 例：https://your-corp-gateway.example.com  或 https://your-gateway/anthropic
ANTHROPIC_BASE_URL=

# OpenAI
OPENAI_API_KEY=
# 例：https://your-corp-gateway.example.com/v1  或 https://api.openai-proxy.com/v1
# 注意：通常需要带 /v1 路径
OPENAI_BASE_URL=

# ===== AI 生图 =====
# 默认复用 OPENAI_API_KEY + OPENAI_BASE_URL 调 dall-e-3 / gpt-image-1
# 如果你的内部网关「不支持」生图，可以单独给生图配一对 key（比如官方 OpenAI Key 走代理）
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_BASE_URL=

# ===== 兜底图源 =====
# https://unsplash.com/developers 申请 access key（每小时 50 次免费）
UNSPLASH_ACCESS_KEY=

# ===== 代理（梯子） =====
# 例：http://127.0.0.1:7890  或  socks5://127.0.0.1:1080
# 如果内部网关本身在内网可达，无需设代理
HTTPS_PROXY=
HTTP_PROXY=
